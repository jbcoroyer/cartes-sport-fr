# Copier ce fichier en .env.local et remplir les valeurs
# Supabase → Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_cle_anon

# Service role — serveur uniquement, jamais côté client
SUPABASE_SERVICE_ROLE_KEY=votre_cle_service_role

# Mot de passe DB (scripts de migration locaux)
SUPABASE_DB_PASSWORD=votre_mot_de_passe_db

# Google Vision API (scanner)
GOOGLE_VISION_API_KEY=votre_cle_google_vision

# URL publique de l'app (OAuth)
NEXT_PUBLIC_APP_URL=http://localhost:3000
