# Supabase — récupère ces valeurs dans Settings > API de ton projet Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Supabase Service Role (côté serveur uniquement, jamais exposé au client)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Google Vision API (pour le scanner)
# Créer une clé sur https://console.cloud.google.com
GOOGLE_VISION_API_KEY=AIza...

# URL de l'app (pour les redirections OAuth)
NEXT_PUBLIC_APP_URL=http://localhost:3000
